# Skopiuj ten plik do .env i uzupełnij wartości
# cp .env.example .env

# ================================
# AI (OpenAI)
# ================================
# Klucz API z https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ================================
# Baza danych (Turso)
# ================================
# URL bazy z https://turso.tech
DATABASE_URL=
# Token autoryzacyjny
DATABASE_AUTH_TOKEN=

# ================================
# Convex
# ================================
# URL z Convex dashboard (np. https://happy-animal-123.convex.cloud)
PUBLIC_CONVEX_URL=

# ================================
# Aplikacja
# ================================
# URL aplikacji (lokalnie: http://localhost:5173)
PUBLIC_APP_URL=http://localhost:5173
